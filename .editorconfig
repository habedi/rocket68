# https://EditorConfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{c,h}]
max_line_length = 100

[*.{zig,zon}]
max_line_length = 100

[*.md]
max_line_length = 150
trim_trailing_whitespace = false

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.sh]
indent_size = 2
