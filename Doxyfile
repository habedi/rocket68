# Doxyfile simplified configuration
# Doxygen version 1.9.8

#---------------------------------------------------------------------------
# Project related settings
#---------------------------------------------------------------------------
PROJECT_NAME       = "Rocket 68"
PROJECT_BRIEF      = "A Motorola 68000 CPU emulator in C"
OUTPUT_DIRECTORY   = site
CREATE_SUBDIRS     = NO

#---------------------------------------------------------------------------
# Input settings
#---------------------------------------------------------------------------
INPUT              = .
FILE_PATTERNS      = *.c *.h
RECURSIVE          = YES
EXTRACT_ALL        = YES
EXCLUDE_PATTERNS   = tests benches external tmp

#---------------------------------------------------------------------------
# Output formats
#---------------------------------------------------------------------------
# HTML output will be placed in `site/doxygen`
GENERATE_HTML      = YES
HTML_OUTPUT        = doxygen

# LaTeX output will be placed in docs/latex
GENERATE_LATEX     = NO
LATEX_OUTPUT       = latex

#---------------------------------------------------------------------------
# Optional tweaks
#---------------------------------------------------------------------------
QUIET              = YES
WARNINGS           = NO
